# Supabase (Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret for optional HTTP agent routes (curl / thin clients)
AGENT_SECRET=generate-a-long-random-string

# Local dev (Render sets PORT automatically)
# PORT=3579
# HOST=0.0.0.0

# Verbose request + dataset logging (set to "true" or "1" to enable)
# DEBUG=false
