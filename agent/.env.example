SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
AGENT_ID=home-pc

# ── Browser connection ──────────────────────────────────────────────────────
#
# CDP_URL points the agent at a real running Chrome so checks use your actual
# browser session (real cookies, real IP, real fingerprints) — bypassing
# bot-protection like Akamai Bot Manager on Home Depot, Walmart, etc.
#
# How to launch Chrome with remote debugging enabled:
#
#   macOS:
#     /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome \
#       --remote-debugging-port=9222 --no-first-run --no-default-browser-check
#
#   Windows (run in cmd or PowerShell):
#     "C:\Program Files\Google\Chrome\Application\chrome.exe" --remote-debugging-port=9222
#
#   Linux:
#     google-chrome --remote-debugging-port=9222
#
# Then set CDP_URL below and restart the agent.
# If CDP_URL is unset or Chrome is not reachable, the agent falls back to
# headless Chrome automatically.
#
# CDP_URL=http://localhost:9222

# Optional
# POLL_INTERVAL_MS=30000
# HEARTBEAT_INTERVAL_MS=30000
