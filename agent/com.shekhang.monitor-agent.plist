<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.shekhang.monitor-agent</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/node</string>
    <string>/Users/shekhangng/Documents/ai/monitor-antigravity/agent/index.js</string>
  </array>

  <!-- Run immediately on load and keep alive after crashes -->
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>WorkingDirectory</key>
  <string>/Users/shekhangng/Documents/ai/monitor-antigravity/agent</string>

  <!-- Throttle restarts: don't restart more than once per 10s -->
  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>/tmp/monitor-agent.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/monitor-agent-error.log</string>
</dict>
</plist>
